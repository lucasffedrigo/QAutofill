{
  "manifest_version": 3,
  "name": "QAutofiller",
  "version": "1.2",
  "description": "Preencha formulários instantaneamente com dados baseados em técnicas do CTFL/ISTQB: Valores Limites, Partições, CPF/CNPJ e mais.",
  "permissions": [
    "activeTab",
    "contextMenus"
  ],
  "host_permissions": [
    "https://viacep.com.br/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/16x16.png",
      "32": "icons/32x32.png"
    },
    "default_title": "QAutofill"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/16x16.png",
    "48": "icons/48x48.png",
    "128": "icons/128x128.png"
  }
}